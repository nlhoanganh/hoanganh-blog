# ─── Java / Maven ────────────────────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear

# Uploaded user images (stored at runtime, not source)
backend/uploads/

# ─── Node / Frontend ─────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# Local env files (may contain secrets / API URLs)
frontend/.env*.local
frontend/.env.production

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
!backend/.idea/.gitignore
*.iml
.vscode/
*.suo
*.user

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs & temps ────────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
